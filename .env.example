# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/kibilov_db"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_super_secret_jwt_key_kibilov_2025
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_refresh_secret_kibilov_2025
JWT_REFRESH_EXPIRES_IN=30d

# ── Frontend URL (CORS) ───────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
# Production:
# CLIENT_URL=https://kibilov.ge

# ── FINA ERP ─────────────────────────────────────────────────────────────────
FINA_API_URL=https://api.fina.ge/api
FINA_API_KEY=your_fina_api_key_here
FINA_COMPANY_ID=your_company_id
# FINA sync interval (cron): every 30 min
FINA_SYNC_INTERVAL="*/30 * * * *"

# ── BOG Payment ───────────────────────────────────────────────────────────────
BOG_CLIENT_ID=your_bog_client_id
BOG_CLIENT_SECRET=your_bog_client_secret
BOG_API_URL=https://api.bog.ge/payments/v1
BOG_CALLBACK_URL=https://api.kibilov.ge/api/payment/bog/callback
BOG_SUCCESS_URL=https://kibilov.ge/payment/success
BOG_FAIL_URL=https://kibilov.ge/payment/fail

# ── TBC Payment ───────────────────────────────────────────────────────────────
TBC_API_KEY=your_tbc_api_key
TBC_CLIENT_ID=your_tbc_client_id
TBC_API_URL=https://api.tbcbank.ge/v1
TBC_CALLBACK_URL=https://api.kibilov.ge/api/payment/tbc/callback
TBC_SUCCESS_URL=https://kibilov.ge/payment/success
TBC_FAIL_URL=https://kibilov.ge/payment/fail

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Kibilov AutoParts <no-reply@kibilov.ge>"
ADMIN_EMAIL=admin@kibilov.ge

# ── WhatsApp (Twilio) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ADMIN_WHATSAPP=whatsapp:+995577575052

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL_LOGIN=admin@kibilov.ge
ADMIN_PASSWORD=Admin@Kibilov2025!

# ── Delivery zones (GEL) ─────────────────────────────────────────────────────
DELIVERY_TBILISI=5
DELIVERY_RUSTAVI=5
DELIVERY_MTSKHETA=7
DELIVERY_GORI=8
DELIVERY_KUTAISI=10
DELIVERY_OTHER=10
FREE_DELIVERY_FROM=150
